# Database
SUPABASE_DB_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_KEY=eyJ...

# Security
API_KEY=your_secret_api_key_here
CORS_ORIGINS=https://admin.yourdomain.com,http://localhost:3001,http://localhost:3000
# Docker: host port for React (compose maps ${FRONTEND_HOST_PORT:-3001} → container 3000). Override if 3001 is busy.
# FRONTEND_HOST_PORT=3000
STRICT_VARIABLE_CHECK=false

# Redis (for Celery)
REDIS_URL=redis://redis:6379/0

# LLM
OPENROUTER_API_KEY=sk-or-...
DEFAULT_MODEL=openai/gpt-5
ANALYST_MODEL=google/gemini-2.5-pro
# Optional: default HTTP timeout per completion (seconds)
# LLM_REQUEST_TIMEOUT=600
# Per-model overrides: "openai/gpt-5-mini=900,openai/gpt-5=900"
# LLM_MODEL_TIMEOUTS=
# OpenRouter fallback routing: primary=fb1|fb2 (see OpenRouter models array)
# LLM_MODEL_FALLBACKS=

# SERP & Scraping
DATAFORSEO_LOGIN=your_login
DATAFORSEO_PASSWORD=your_password
SERPER_API_KEY=...
SERPAPI_KEY=...
SERP_CACHE_ENABLED=true
SERP_CACHE_TTL=86400
SCRAPE_CACHE_TTL=43200

# Telegram notifications
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=-1003841650237

# Celery
CELERY_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=900

# Image Generation (optional) — OpenRouter image models + ImgBB
IMAGE_GEN_ENABLED=false
IMGBB_API_KEY=
IMAGE_MODEL_DEFAULT=google/gemini-2.5-flash-image-preview
